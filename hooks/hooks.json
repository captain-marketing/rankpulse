{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__dataforseo__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/cost-tracker.py\" --pre"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__dataforseo__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/cost-tracker.py\" --post"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/cost-tracker.py\" --summary"
          }
        ]
      }
    ]
  }
}
